generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id
  name      String?
  email     String    @unique
  image     String?
  createdAt DateTime  @default(now())
  ideas     Idea[]
  comments  Comment[]
}

model Idea {
  id          String    @id @default(cuid())
  title       String
  oneLiner    String
  explanation String
  createdAt   DateTime  @default(now())
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags        IdeaTag[]
  comments    Comment[]
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  ideas IdeaTag[]
}

model IdeaTag {
  ideaId String
  tagId  String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([ideaId, tagId])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  createdAt DateTime  @default(now())
  authorId  String
  ideaId    String
  parentId  String?
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  idea      Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("replies")
}
